# Copy this file to .env before running against the real APIs.
# Do not commit .env. Even public challenge keys should be treated like secrets.

OPENVOLT_API_KEY="paste-the-challenge-x-api-key-here"
OPENVOLT_API_HOST="https://api.openvolt.com"
CARBON_INTENSITY_API_HOST="https://api.carbonintensity.org.uk"

# Challenge defaults
METER_ID="6514167223e3d1424bf82742"
REPORT_FROM="2023-01-01T00:00:00.000Z"
REPORT_TO="2023-02-01T00:00:00.000Z"

# Use `npm run report:mock` to test the whole pipeline without hitting APIs.
MOCK_MODE="false"
